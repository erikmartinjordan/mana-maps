<script src="js/plans.js"></script>
<script src="js/upsell.js"></script>

<!-- ═══ Lógica de búsqueda ═══ -->
<script>
(function() {
  var searchInput = document.getElementById('search-input');
  var searchDropdown = document.getElementById('search-dropdown');
  var searchDebounce = null;

  if (!searchInput) return;

  searchInput.addEventListener('input', function() {
    var q = this.value.trim();
    if (searchDebounce) clearTimeout(searchDebounce);
    if (q.length < 2) { searchDropdown.classList.remove('open'); return; }
    searchDebounce = setTimeout(function() { doSearch(q); }, 350);
  });

  searchInput.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { searchDropdown.classList.remove('open'); this.blur(); }
    if (e.key === 'Enter') {
      e.preventDefault();
      var first = searchDropdown.querySelector('.search-result');
      if (first) first.click();
    }
  });

  // Close dropdown on click outside
  document.addEventListener('click', function(e) {
    var wrap = document.getElementById('search-wrap');
    if (wrap && !wrap.contains(e.target)) searchDropdown.classList.remove('open');
  });

  async function doSearch(q) {
    try {
      var r = await fetch(
        'https://nominatim.openstreetmap.org/search?q=' + encodeURIComponent(q) + '&format=json&limit=5',
        { headers: { 'Accept-Language': 'es', 'User-Agent': 'ManaMaps/1.0' } }
      );
      var results = await r.json();
      if (!results.length) {
        searchDropdown.innerHTML = '<div class="search-no-results">Sin resultados</div>';
        searchDropdown.classList.add('open');
        return;
      }
      searchDropdown.innerHTML = results.map(function(r) {
        var name = r.display_name.length > 70 ? r.display_name.substring(0,67) + '...' : r.display_name;
        var type = r.type || r.class || '';
        return '<button class="search-result" data-lat="' + r.lat + '" data-lng="' + r.lon + '">' +
          '<svg class="search-result-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>' +
          '<span class="search-result-text">' + name.replace(/</g,'&lt;') + '</span>' +
          '<span class="search-result-type">' + type + '</span>' +
          '</button>';
      }).join('');
      searchDropdown.classList.add('open');

      // Bind click events
      searchDropdown.querySelectorAll('.search-result').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var lat = parseFloat(this.dataset.lat);
          var lng = parseFloat(this.dataset.lng);
          map.setView([lat, lng], 14);
          searchDropdown.classList.remove('open');
          searchInput.value = '';
          searchInput.blur();
        });
      });
    } catch(e) {
      console.warn('Search error:', e);
    }
  }

})();
</script>

<!-- ═══ Lógica de paneles ═══ -->
<script>
(function() {
  let activePanel = 'draw';

  window.togglePanel = function(panel) {
    var fp = document.getElementById('float-panel');
    var icons = document.querySelectorAll('#toolbar .tool-icon[data-panel]');

    if (activePanel === panel) {
      // Close panel
      fp.classList.remove('open');
      icons.forEach(function(i) { i.classList.remove('active'); });
      activePanel = null;
      if (typeof map !== 'undefined') map.invalidateSize();
      return;
    }

    // Open/switch panel
    activePanel = panel;
    icons.forEach(function(i) {
      i.classList.toggle('active', i.dataset.panel === panel);
    });
    document.querySelectorAll('.panel-state').forEach(function(p) {
      p.classList.toggle('visible', p.id === 'panel-' + panel);
    });
    fp.classList.add('open');
    if (typeof map !== 'undefined') map.invalidateSize();
  };

  // Update element count in topbar
  function updateMapNameCount() {
    var el = document.getElementById('map-name-count');
    if (!el) return;
    var total = 0;
    if (typeof drawnItems !== 'undefined') {
      drawnItems.eachLayer(function() { total++; });
    }
    el.textContent = total > 0 ? '\u00b7 ' + total + ' elemento' + (total !== 1 ? 's' : '') : '';
  }

  // Monkey-patch stats to also update count
  var _origStats2 = typeof stats === 'function' ? stats : function(){};
  window.stats = function() {
    _origStats2();
    updateMapNameCount();
  };

  // Init project name
  var projInput = document.getElementById('project-name-input');
  if (projInput && typeof getProjectName === 'function') {
    projInput.value = getProjectName();
  }
  updateMapNameCount();
})();
</script>
</body>
</html>
