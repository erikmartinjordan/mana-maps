<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Maña Maps — Editor de mapas online gratuito con IA</title>
<link rel="icon" type="image/svg+xml" href="favicon.svg"/>
<!-- SEO Meta -->
<meta name="description" content="Crea y edita mapas interactivos online. Dibuja puntos, líneas y polígonos. Exporta a GeoJSON, KML, Shapefile y CSV. Chat con IA en español. Sin registro, sin instalación.">
<meta name="keywords" content="editor mapas online, crear mapa online, dibujar mapa, exportar KML, exportar shapefile, GeoJSON editor, mapa interactivo, herramienta GIS online, editar mapa gratis">
<link rel="canonical" href="https://mana-maps.com/">
<link rel="alternate" hreflang="es" href="https://mana-maps.com/">
<link rel="alternate" hreflang="en" href="https://mana-maps.com/en/">
<link rel="alternate" hreflang="x-default" href="https://mana-maps.com/en/">

<!-- Open Graph -->
<meta property="og:type" content="website">
<meta property="og:url" content="https://mana-maps.com/">
<meta property="og:title" content="Maña Maps — Editor de mapas online con IA">
<meta property="og:description" content="Crea mapas interactivos, dibuja geometrías y exporta a cualquier formato GIS. Chat con IA en lenguaje natural.">
<meta property="og:image" content="https://mana-maps.com/og-image-es.png">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:locale" content="es_ES">
<meta property="og:locale:alternate" content="en_US">
<meta property="og:site_name" content="Maña Maps">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Maña Maps — Editor de mapas online con IA">
<meta name="twitter:description" content="Dibuja en el mapa, exporta a GeoJSON, KML o Shapefile. Chat IA en español. Gratis y sin registro.">
<meta name="twitter:image" content="https://mana-maps.com/og-image-es.png">

<!-- Structured Data (JSON-LD) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Maña Maps",
  "url": "https://mana-maps.com",
  "description": "Editor de mapas interactivo online con exportación a GeoJSON, KML, Shapefile y CSV. Chat con inteligencia artificial en español.",
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR"
  },
  "featureList": [
    "Dibujar puntos, líneas y polígonos",
    "Exportar a GeoJSON, KML, KMZ, Shapefile, CSV",
    "Importar GeoJSON, KML, KMZ, Shapefile",
    "Chat IA en lenguaje natural",
    "Vista satélite y globo 3D",
    "Sin registro requerido"
  ],
  "inLanguage": ["es", "en"],
  "screenshot": "https://mana-maps.com/og-image-es.png",
  "author": {
    "@type": "Person",
    "name": "Erik Martín Jordán",
    "url": "https://erikmartinjordan.com"
  }
}
</script>

<meta name="robots" content="index, follow">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<link rel="stylesheet" href="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.css"/>
<link href="https://unpkg.com/maplibre-gl@5/dist/maplibre-gl.css" rel="stylesheet" />
<link rel="stylesheet" href="styles.css"/>

<!-- ═══ Estilos de componentes ═══ -->
<style>
/* ── Auto-save pill ── */
.autosave-pill {
  opacity: 0.5;
  transition: opacity .3s, background .3s;
  font-size: 11px;
}
.autosave-pill.flash {
  opacity: 1;
  background: var(--color-accent, #0ea5e9);
  color: #fff;
}

/* ── Coordinate toggle button ── */
.coords-toggle-btn {
  background: var(--color-background-secondary, rgba(255,255,255,.08));
  border: 1px solid var(--color-border-tertiary, rgba(255,255,255,.12));
  color: var(--color-text-secondary, #94a3b8);
  font-size: 10px;
  font-weight: 600;
  padding: 1px 6px;
  border-radius: 4px;
  cursor: pointer;
  font-family: 'DM Mono', monospace;
  line-height: 1.4;
}
.coords-toggle-btn:hover {
  background: var(--color-background-tertiary, rgba(255,255,255,.14));
  color: var(--color-text-primary, #e2e8f0);
}

/* ── WMS layer list ── */
.wms-layer-item {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 4px 0;
  font-size: 12px;
  color: var(--color-text-secondary, #94a3b8);
}
.wms-eye-btn, .wms-remove-btn {
  background: none;
  border: none;
  color: var(--color-text-secondary, #94a3b8);
  cursor: pointer;
  padding: 2px;
  display: flex;
  align-items: center;
}
.wms-eye-btn svg, .wms-remove-btn svg { width: 14px; height: 14px; }
.wms-eye-btn.off { opacity: 0.4; }
.wms-eye-btn:hover, .wms-remove-btn:hover { color: var(--color-text-primary, #e2e8f0); }
.wms-remove-btn { font-size: 16px; margin-left: auto; }
.wms-layer-label {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ── Upgrade modal ── */
.upgrade-modal{display:none;position:fixed;inset:0;z-index:9999;align-items:center;justify-content:center;}
.upgrade-modal.open{display:flex;}
.upgrade-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.6);}
.upgrade-box{position:relative;background:var(--color-background-primary,#16161e);border:1px solid var(--color-border-tertiary,rgba(255,255,255,.12));border-radius:14px;padding:28px 24px 22px;max-width:300px;width:90%;text-align:center;z-index:1;box-shadow:0 16px 48px rgba(0,0,0,.4);}
.upgrade-box h3{font-size:15px;font-weight:700;color:var(--color-text-primary,#e2e8f0);margin-bottom:6px;}
.upgrade-box p{font-size:12px;color:var(--color-text-secondary,#94a3b8);line-height:1.5;margin-bottom:16px;}
.upgrade-price{font-family:'DM Mono',monospace;font-size:28px;font-weight:600;color:var(--color-text-primary,#e2e8f0);letter-spacing:-1px;}
.upgrade-period{font-size:11px;color:var(--color-text-secondary,#94a3b8);margin-left:2px;}
.upgrade-row{margin-bottom:18px;}
.upgrade-cta{display:block;width:100%;padding:10px;border:none;border-radius:50px;background:var(--color-accent,#0ea5e9);color:#fff;font-size:13px;font-weight:700;cursor:pointer;margin-bottom:8px;transition:opacity .15s;}
.upgrade-cta:hover{opacity:.85;}
.upgrade-skip{display:block;width:100%;padding:6px;border:none;background:none;color:var(--color-text-secondary,#94a3b8);font-size:11px;cursor:pointer;}
.upgrade-skip:hover{color:var(--color-text-primary,#e2e8f0);}
</style>
</head>
<body>
<div id="toast" aria-live="polite"></div>

<!-- ═══ Alerta in-app ═══ -->
<div id="mana-alert" class="mana-alert">
  <span class="mana-alert-icon"></span>
  <span class="mana-alert-text"></span>
</div>

<!-- ═══ Diálogo de confirmación ═══ -->
<div id="confirm-modal" class="confirm-modal">
  <div class="confirm-modal-box">
    <p id="confirm-modal-msg"></p>
    <div class="confirm-modal-btns">
      <button class="modal-btn modal-btn-cancel" onclick="confirmCancel()">Cancelar</button>
      <button class="modal-btn modal-btn-ok" onclick="confirmOk()">Confirmar</button>
    </div>
  </div>
</div>


<!-- ═══ Modal upsell ═══ -->
<div id="upsell-modal" class="upsell-modal">
  <div class="upsell-box">
    <button class="upsell-close" onclick="closeUpsell()">&times;</button>
    <h3 class="upsell-title">Ma&#241;a Maps Pro</h3>
    <div class="upsell-price">4,99 &#8364; <span class="upsell-period">/ mes</span></div>
    <div class="upsell-benefits">
      <div class="upsell-benefit">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        <div><strong>IA incluida</strong><span>Sin configurar nada</span></div>
      </div>
      <div class="upsell-benefit">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/><line x1="2" y1="12" x2="22" y2="12"/></svg>
        <div><strong>Todos los modelos de lenguaje</strong><span>GPT-4o, Claude, Llama y m&#225;s</span></div>
      </div>
      <div class="upsell-benefit">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        <div><strong>Soporte prioritario</strong><span>Respuesta directa del equipo</span></div>
      </div>
    </div>
    <button class="upsell-cta" onclick="upsellBuy()">Empezar ahora</button>
    <button class="upsell-secondary" onclick="upsellHaveKey()">Ya tengo una clave API</button>
    <p class="upsell-note">Recibir&#225;s tu clave API por email tras el pago &#183; Cancela cuando quieras</p>
  </div>
</div>

<!-- ═══ Modal nombre ═══ -->
<div id="name-modal">
  <h4 id="name-modal-title">Nombre del elemento</h4>
  <input id="name-modal-input" type="text" placeholder="Sin nombre" maxlength="80" autocomplete="off"/>
  <div id="name-modal-btns">
    <button class="modal-btn modal-btn-cancel" onclick="modalCancel()">Cancelar</button>
    <button class="modal-btn modal-btn-ok" onclick="modalOk()">Guardar</button>
  </div>
</div>

<!-- ═══ Barra superior ═══ -->
<div id="topbar">
  <a class="mana-logo-wrap" href="#">
    <div class="mana-logo-icon">
      <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
        <path fill="#30363B" stroke="rgba(1,1,1,0.5)" stroke-width="1"
          d="M42.3,-74.7C55.1,-65.8,66.1,-55.2,74.7,-42.4C83.2,-29.7,89.3,-14.8,89.7,0.2C90,15.2,84.6,30.5,74.3,40.2C64,49.8,48.7,54,35.6,62.1C22.4,70.2,11.2,82.3,-0.8,83.6C-12.7,84.9,-25.4,75.4,-36.1,65.9C-46.9,56.4,-55.6,46.8,-61.3,35.8C-66.9,24.8,-69.5,12.4,-72,-1.4C-74.5,-15.3,-76.9,-30.5,-70.9,-41C-64.9,-51.4,-50.6,-57.1,-37.4,-65.8C-24.2,-74.5,-12.1,-86.1,1.3,-88.4C14.7,-90.7,29.5,-83.6,42.3,-74.7Z"
          transform="translate(100 100)"/>
      </svg>
      <span>M&#771;</span>
    </div>
    <span class="logo-wordmark">Ma&#241;a</span><span class="logo-sub">Maps</span>
  </a>
  <div class="topbar-map-name">
    <input type="text" id="project-name-input" class="map-name-input" placeholder="Mapa sin t&#237;tulo" maxlength="40" autocomplete="off"
      onchange="setProjectName(this.value)"/>
    <span class="map-name-count" id="map-name-count"></span>
  </div>
  <!-- Buscador de lugares -->
  <div class="search-wrap" id="search-wrap">
    <div class="search-input-wrap">
      <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" id="search-input" class="search-input" placeholder="Buscar lugar..." autocomplete="off" spellcheck="false"/>
    </div>
    <div class="search-dropdown" id="search-dropdown"></div>
  </div>
  <div class="topbar-right">
    <button class="mobile-toggle" id="mobile-sidebar-toggle" aria-label="Herramientas">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <button class="btn btn-ghost" onclick="clearAll()">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/></svg>
      <span class="btn-text">Limpiar mapa</span>
    </button>
    <button class="btn btn-ghost" onclick="shareMapURL()">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
      <span class="btn-text">Compartir</span>
    </button>
    <div class="menu-wrap">
      <button class="btn btn-ghost" onclick="toggleMenu('import-menu',event)">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 5 17 10"/><line x1="12" y1="5" x2="12" y2="17"/></svg>
        <span class="btn-text">Importar</span>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="drop-menu" id="import-menu">
        <button class="drop-item" onclick="importTrigger('.geojson,.json')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>GeoJSON</button>
        <button class="drop-item" onclick="importTrigger('.kml')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>KML</button>
        <button class="drop-item" onclick="importTrigger('.kmz')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>KMZ</button>
        <div class="drop-divider"></div>
        <button class="drop-item" onclick="importTrigger('.zip,.shp')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>Shapefile (.zip)</button>
      </div>
    </div>
    <input type="file" id="file-import" style="display:none" onchange="handleImport(event)">
    <div class="menu-wrap">
      <button class="btn btn-primary" onclick="toggleMenu('export-menu',event)">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        <span class="btn-text">Exportar</span>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="drop-menu" id="export-menu">
        <button class="drop-item" onclick="exportAs('geojson')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>GeoJSON</button>
        <button class="drop-item" onclick="exportAs('csv')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="16" y2="17"/></svg>CSV</button>
        <button class="drop-item" onclick="exportAs('kml')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>KML / KMZ</button>
        <div class="drop-divider"></div>
        <button class="drop-item" onclick="exportAs('shapefile')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>Shapefile (.zip)</button>
      </div>
    </div>
    <div class="lang-switcher">
      <a href="/" class="lang-btn active" hreflang="es">ES</a>
      <span class="lang-sep">/</span>
      <a href="/en/" class="lang-btn" hreflang="en">EN</a>
    </div>
    <button class="mobile-toggle" id="mobile-chat-toggle" aria-label="Chat">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
    </button>
  </div>
</div>

<!-- ═══ Backdrop móvil ═══ -->
<div id="mobile-backdrop"></div>

<!-- ═══ Layout principal ═══ -->
<div id="app">
  <!-- ═══ Sidebar ═══ -->
  <div id="sidebar">
    <!-- Toolbar: iconos -->
    <div id="toolbar">
      <div class="tool-icon active" data-panel="draw" onclick="togglePanel('draw')" title="Dibujar">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      </div>
      <div class="tool-icon" data-panel="style" onclick="togglePanel('style')" title="Estilo">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
      </div>
      <div class="tool-icon" data-panel="basemap" onclick="togglePanel('basemap')" title="Mapa base">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/></svg>
      </div>
      <div class="tool-sep"></div>
      <div class="tool-icon" data-panel="layers" onclick="togglePanel('layers')" title="Capas">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
      </div>
      <div class="tool-sep"></div>
      <div class="tool-icon" id="tb-ruler" onclick="setTool('ruler')" title="Medir distancia">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="8" width="20" height="8" rx="1" transform="rotate(-45 12 12)"/><line x1="9" y1="9" x2="9" y2="12"/><line x1="12" y1="6" x2="12" y2="9"/><line x1="15" y1="9" x2="15" y2="12"/></svg>
      </div>
      <div class="toolbar-bottom">
        <div class="tool-icon" data-panel="ogc" onclick="togglePanel('ogc')" title="Servicios OGC">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
        </div>

      </div>
    </div>

    <!-- Panel flotante contextual -->
    <div id="float-panel" class="open">

      <!-- ═══ Panel de dibujo ═══ -->
      <div class="panel-state visible" id="panel-draw">
        <div class="panel-header">
          <div class="panel-header-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></div>
          <div><div class="panel-header-title">Herramientas</div><div class="panel-header-sub">Dibujo y edici&#243;n</div></div>
        </div>
        <div class="panel-body">
          <button class="draw-btn" id="btn-point" onclick="setTool('point')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5" fill="currentColor" stroke="none"/></svg>
            Añadir punto
          </button>
          <button class="draw-btn" id="btn-line" onclick="setTool('line')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="20" x2="20" y2="4"/><circle cx="4" cy="20" r="2" fill="currentColor" stroke="none"/><circle cx="20" cy="4" r="2" fill="currentColor" stroke="none"/></svg>
            Dibujar línea
          </button>
          <button class="draw-btn" id="btn-polygon" onclick="setTool('polygon')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12,3 21,19 3,19"/></svg>
            Dibujar polígono
          </button>
          <button class="draw-btn" id="btn-ruler" onclick="setTool('ruler')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="8" width="20" height="8" rx="1" transform="rotate(-45 12 12)"/><line x1="9" y1="9" x2="9" y2="12"/><line x1="12" y1="6" x2="12" y2="9"/><line x1="15" y1="9" x2="15" y2="12"/></svg>
            Medir distancia
          </button>
          <div class="p-sep"></div>
          <button class="draw-btn" id="btn-edit" onclick="toggleEdit()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 3a2.83 2.83 0 114 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>
            Editar geometria
          </button>
        </div>
      </div>

      <!-- ═══ Panel de estilo ═══ -->
      <div class="panel-state" id="panel-style">
        <div class="panel-header">
          <div class="panel-header-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg></div>
          <div><div class="panel-header-title">Estilo</div><div class="panel-header-sub">Colores y marcadores</div></div>
        </div>
        <div class="panel-body">
          <div class="sec-label">Color</div>
          <div class="color-row swatch-row" id="color-row"></div>
          <div class="sec-label">Tipo de marcador</div>
          <div class="marker-row" id="marker-row">
            <div class="marker-opt active" data-mtype="pin" title="Pin" onclick="setMarkerType('pin',this)">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5" fill="currentColor" stroke="none"/></svg>
            </div>
            <div class="marker-opt" data-mtype="circle" title="C&#237;rculo" onclick="setMarkerType('circle',this)">
              <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="7"/></svg>
            </div>
            <div class="marker-opt" data-mtype="square" title="Cuadrado" onclick="setMarkerType('square',this)">
              <svg viewBox="0 0 24 24" fill="currentColor"><rect x="4" y="4" width="16" height="16" rx="3"/></svg>
            </div>
            <div class="marker-opt" data-mtype="star" title="Estrella" onclick="setMarkerType('star',this)">
              <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12,2 15,9 22,9 17,14 19,21 12,17 5,21 7,14 2,9 9,9"/></svg>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══ Panel de mapa base ═══ -->
      <div class="panel-state" id="panel-basemap">
        <div class="panel-header">
          <div class="panel-header-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/></svg></div>
          <div><div class="panel-header-title">Mapa base</div><div class="panel-header-sub">Tipo de vista</div></div>
        </div>
        <div class="panel-body">
          <div class="basemap-grid">
            <button class="basemap-card active" id="bmc-map" onclick="setBaseLayer('map')">
              <div class="basemap-thumb basemap-thumb-map"></div>
              <div class="basemap-label">Mapa</div>
            </button>
            <button class="basemap-card" id="bmc-sat" onclick="setBaseLayer('satellite')">
              <div class="basemap-thumb basemap-thumb-sat"></div>
              <div class="basemap-label">Sat&#233;lite</div>
            </button>
            <button class="basemap-card" id="bmc-globe" onclick="setBaseLayer('globe')">
              <div class="basemap-thumb basemap-thumb-globe"></div>
              <div class="basemap-label">Globo 3D</div>
            </button>
          </div>
        </div>
      </div>

      <!-- ═══ Panel de capas ═══ -->
      <div class="panel-state" id="panel-layers">
        <div class="panel-header">
          <div class="panel-header-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg></div>
          <div><div class="panel-header-title">Capas</div><div class="panel-header-sub">Elementos del mapa</div></div>
        </div>
        <div class="panel-body">
          <div id="layer-list">
            <p class="empty-note">A&#250;n no hay elementos.<br>Dibuja en el mapa o usa el chat.</p>
          </div>
        </div>
      </div>

      <!-- ═══ Panel OGC ═══ -->
      <div class="panel-state" id="panel-ogc">
        <div class="panel-header">
          <div class="panel-header-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg></div>
          <div><div class="panel-header-title">Servicios OGC</div><div class="panel-header-sub">WMS y WFS</div></div>
        </div>
        <div class="panel-body">
          <input type="text" id="ogc-url-input" class="ogc-input" placeholder="Servicio WMS o WFS" autocomplete="off" spellcheck="false"/>
          <div id="wms-layer-list"></div>
          <button class="draw-btn ogc-catalog-toggle" onclick="toggleOGCCatalog()">
            <svg id="ogc-cat-chevron" class="ogc-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
            Catálogo de servicios
          </button>
          <div id="ogc-catalog-list" style="display:none"></div>
        </div>
      </div>


        <div class="panel-footer">
          <div id="pro-indicator" class="pro-indicator not-configured" onclick="showUpsell()">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            Activa la IA Pro &#8594;
          </div>
          <div class="panel-footer-links">
            <a class="panel-footer-link" href="/about">Acerca de</a>
            <a class="panel-footer-link" href="/changelog">Changelog</a>
            <a class="panel-footer-link" href="/open">Estad&#237;sticas</a>
          </div>
        </div>
    </div>
  </div>

  <div class="resize-handle" id="handle-left"></div>

  <!-- ═══ Mapa ═══ -->
  <div id="map-wrap">
    <div id="map"></div>
    <div id="coords-overlay">
      <div id="mouse-coords">&#8212; , &#8212;</div>
      <button id="coords-format-btn" class="coords-toggle-btn" onclick="toggleCoordsFormat()" title="Alternar DD / DMS">DMS</button>
    </div>
    <div id="globe"></div>
    <div class="globe-atmosphere" id="globe-atmo"></div>
    <div id="globe-controls">
      <button onclick="globeZoomIn()" title="Acercar">+</button>
      <button onclick="globeZoomOut()" title="Alejar">&#8722;</button>
      <button onclick="toggleSpin()" id="btn-spin" title="Auto-rotaci&#243;n">&#8635;</button>
    </div>
    <div id="globe-spin-indicator">&#8635; Auto-rotaci&#243;n activa</div>
    <div id="draw-hint">Haz clic en el mapa para dibujar</div>
    <div id="ruler-tooltip"></div>
    <div id="drop-overlay">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
        <polyline points="7 10 12 5 17 10"/><line x1="12" y1="5" x2="12" y2="17"/>
      </svg>
      <span>Suelta para importar</span>
    </div>
    
    <!-- ═══ Modal tabla de atributos ═══ -->
    <div id="attr-modal" class="attr-modal">
      <div class="attr-modal-box">
        <div class="attr-modal-header">
          <span class="attr-modal-title" id="attr-modal-title">Propiedades</span>
          <button class="attr-modal-close" onclick="closeAttrModal()">&times;</button>
        </div>
        <!-- Selector de elementos -->
        <div id="attr-elem-selector" class="attr-elem-selector" style="display:none"></div>
        <!-- Filas de propiedades -->
        <div class="attr-modal-body" id="attr-modal-body"></div>
        <!-- Botón añadir atributo -->
        <div class="attr-modal-footer">
          <button class="attr-add-btn" onclick="attrAddProperty()">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Añadir atributo
          </button>
        </div>
      </div>
    </div>

        <!-- ═══ Panel de estadísticas ═══ -->
    <div id="stats-panel" class="stats-panel"></div>

    <div id="map-bottom-bar">
      <div class="stat-pill">Puntos <span id="cnt-points">0</span></div>
      <div class="stat-pill">L&#237;neas <span id="cnt-lines">0</span></div>
      <div class="stat-pill">Pol&#237;gonos <span id="cnt-polygons">0</span></div>
      <div class="stat-pill autosave-pill" id="autosave-pill">Auto-guardado</div>
    </div>
  </div>

  <div class="resize-handle" id="handle-right"></div>

  <!-- ═══ Panel de chat ═══ -->
  <div id="chat-panel">
    <div class="chat-header">
      <div class="chat-header-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg></div>
      <div><div class="chat-header-title">Ma&#241;a AI <span class="ai-badge" id="ai-status-badge">IA</span></div><div class="chat-header-sub">Escribe en lenguaje natural</div></div>
      <button class="chat-settings-btn" onclick="openAISettings()" title="Configurar IA">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
      </button>
    </div>
    <div id="chat-messages">
      <div>
        <div class="msg-label">Ma&#241;a AI</div>
        <div class="msg bot">&#161;Hola! Soy <strong>Ma&#241;a AI</strong>, tu asistente de mapas. Prueba con:<br><br>
        <button class="chat-suggestion" onclick="sendChatSuggestion(this.textContent)">📍 a&#241;ade un punto en Barcelona</button>
        <button class="chat-suggestion" onclick="sendChatSuggestion(this.textContent)">🛣️ ruta de Madrid a Sevilla</button>
        <button class="chat-suggestion" onclick="sendChatSuggestion(this.textContent)">🏛️ busca museos en Par&#237;s</button>
        <button class="chat-suggestion" onclick="sendChatSuggestion(this.textContent)">🛰️ sat&#233;lite</button>
        <button class="chat-suggestion" onclick="sendChatSuggestion(this.textContent)">🌍 globo 3D</button>
        <button class="chat-suggestion" onclick="sendChatSuggestion(this.textContent)">🎨 color rojo</button>
        <button class="chat-suggestion" onclick="sendChatSuggestion(this.textContent)">📦 exporta como KML</button><br><br>
        &#9881;&#65039; <strong>Configura una clave API</strong> (&#9881;) para IA con lenguaje natural completo.</div>
      </div>
    </div>
    <div id="chat-input-area">
      <textarea id="chat-input" rows="1" placeholder="Escribe un comando..."></textarea>
      <button id="chat-send"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg></button>
    </div>
  </div>
</div>

<!-- ═══ Modal ajustes IA ═══ -->
<div id="ai-settings-modal" class="ai-modal">
  <div class="ai-modal-content">
    <div class="ai-modal-header">
      <h4>&#9881;&#65039; Configurar IA</h4>
      <button class="ai-modal-close" onclick="closeAISettings()">&times;</button>
    </div>
    <div class="ai-modal-body">
      <label class="ai-label">Proveedor</label>
      <select id="ai-provider" class="ai-input" onchange="toggleEndpointField(this.value)">
        <option value="openai">OpenAI</option>
        <option value="anthropic">Anthropic (Claude)</option>
        <option value="groq">Groq (gratis)</option>
        <option value="together">Together AI</option>
        <option value="custom">Personalizado</option>
      </select>

      <label class="ai-label">Clave API</label>
      <input id="ai-key" type="password" class="ai-input" placeholder="sk-..." autocomplete="off"/>

      <label class="ai-label">Modelo</label>
      <input id="ai-model" type="text" class="ai-input" placeholder="gpt-4o-mini" autocomplete="off"/>

      <div id="ai-endpoint-row" style="display:none">
        <label class="ai-label">Endpoint</label>
        <input id="ai-endpoint" type="text" class="ai-input" placeholder="https://..." autocomplete="off"/>
      </div>

      <div class="ai-hint">
        &#128274; La clave se guarda solo en tu navegador (localStorage).<br>
        &#128161; <strong>Groq</strong> ofrece una clave gratuita en <a href="https://console.groq.com" target="_blank">console.groq.com</a><br>
        &#128161; <strong>Anthropic</strong> en <a href="https://console.anthropic.com" target="_blank">console.anthropic.com</a>
      </div>
    </div>
    <div class="ai-modal-footer">
      <button class="modal-btn modal-btn-cancel" onclick="closeAISettings()">Cancelar</button>
      <button class="modal-btn modal-btn-ok" onclick="saveAISettings()">Guardar</button>
    </div>
  </div>
</div>

<!-- ═══ Menú contextual de capas ═══ -->
<div id="layer-ctx-menu" class="ctx-menu-float">
  <div id="lctx-title" class="ctx-section-label" style="padding-top:10px"></div>

  <!-- Selector de color -->
  <div class="ctx-color-row">
      </div>

  <!-- Grosor de línea -->
  <div id="lctx-weight-row" class="ctx-option-row">
    <span class="ctx-option-label">Grosor</span>
    <div class="ctx-weight-opts">
      <button class="ctx-weight-btn" onclick="lctxSetWeight(1)">1</button>
      <button class="ctx-weight-btn" onclick="lctxSetWeight(2)">2</button>
      <button class="ctx-weight-btn" onclick="lctxSetWeight(3)">3</button>
      <button class="ctx-weight-btn" onclick="lctxSetWeight(5)">5</button>
      <button class="ctx-weight-btn" onclick="lctxSetWeight(8)">8</button>
    </div>
  </div>

  <!-- Opacidad -->
  <div class="ctx-option-row">
    <span class="ctx-option-label">Opacidad</span>
    <input type="range" id="lctx-opacity" class="ctx-range" min="10" max="100" value="100" oninput="lctxSetOpacity(this.value)"/>
    <span id="lctx-opacity-val" class="ctx-range-val">100%</span>
  </div>

  <div class="ctx-sep"></div>

  <!-- Renombrar -->
  <button class="ctx-item" onclick="lctxRename()">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 3a2.83 2.83 0 114 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>
    Renombrar
  </button>

  <!-- Zoom -->
  <button class="ctx-item" onclick="lctxZoom()">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    Zoom a la capa
  </button>

  <!-- Tabla de atributos -->
  <button class="ctx-item" onclick="lctxShowAttrTable()">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
    Ver tabla de atributos
  </button>

  <!-- Categorizar por atributo -->
  <div id="lctx-categorize" style="display:none">
    <div class="ctx-sep"></div>
    <div class="ctx-section-label">Categorizar por atributo</div>
    <div id="lctx-cat-list"></div>
  </div>

  <div class="ctx-sep"></div>

  <!-- Eliminar -->
  <button class="ctx-item danger" onclick="lctxDelete()">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/></svg>
    Eliminar
  </button>
</div>

<!-- ═══ Menú contextual del mapa ═══ -->
<div id="ctx-menu">
  <div class="ctx-coords" id="ctx-coords">0.00000, 0.00000</div>
  <button class="ctx-item" onclick="ctxCopyCoords()">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
    Copiar coordenadas
  </button>
  <button class="ctx-item" onclick="ctxAddPoint()">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/></svg>
    A&#241;adir punto aqu&#237;
  </button>
  <button class="ctx-item" onclick="ctxCenterHere()">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
    Centrar mapa aqu&#237;
  </button>

  <!-- Sección de estilo -->
  <div id="ctx-style-section" style="display:none">
    <div class="ctx-sep"></div>
    <div class="ctx-section-label">Estilo del elemento</div>

    <!-- Selector de color -->
    <div class="ctx-color-row">
    </div>

    <!-- Grosor de línea -->
    <div id="ctx-weight-row" class="ctx-option-row">
      <span class="ctx-option-label">Grosor</span>
      <div class="ctx-weight-opts">
        <button class="ctx-weight-btn" onclick="ctxSetWeight(1)">1</button>
        <button class="ctx-weight-btn" onclick="ctxSetWeight(2)">2</button>
        <button class="ctx-weight-btn" onclick="ctxSetWeight(3)">3</button>
        <button class="ctx-weight-btn" onclick="ctxSetWeight(5)">5</button>
        <button class="ctx-weight-btn" onclick="ctxSetWeight(8)">8</button>
      </div>
    </div>

    <!-- Opacidad -->
    <div class="ctx-option-row">
      <span class="ctx-option-label">Opacidad</span>
      <input type="range" id="ctx-opacity" class="ctx-range" min="10" max="100" value="100" oninput="ctxSetOpacity(this.value)"/>
      <span id="ctx-opacity-val" class="ctx-range-val">100%</span>
    </div>

    <!-- Renombrar -->
    <button class="ctx-item" onclick="ctxRename()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 3a2.83 2.83 0 114 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>
      Renombrar
    </button>

    <!-- Aplicar al grupo -->
    <button class="ctx-item" id="ctx-style-group" onclick="ctxStyleGroup()" style="display:none">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      Aplicar estilo a toda la capa
    </button>

    <!-- Tabla de atributos -->
    <button class="ctx-item" id="ctx-attr-table" onclick="ctxShowAttrTable()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
      Tabla de atributos
    </button>

    <!-- Categorizar por atributo -->
    <div id="ctx-categorize-section" style="display:none">
      <div class="ctx-sep"></div>
      <div class="ctx-section-label">Categorizar por atributo</div>
      <div id="ctx-categorize-list"></div>
    </div>
  </div>

  <div class="ctx-sep"></div>
  <button class="ctx-item danger" id="ctx-delete-layer" onclick="ctxDeleteLayer()" style="display:none">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/></svg>
    Borrar este elemento
  </button>
  <button class="ctx-item danger" onclick="clearAll()">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
    Borrar todo
  </button>
</div>

<!-- ═══ Librerías externas ═══ -->
<script src="https://unpkg.com/shpjs@4.0.4/dist/shp.js"></script>
<script src="https://unpkg.com/jszip@3.10.1/dist/jszip.min.js"></script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.js"></script>
<script src="https://unpkg.com/maplibre-gl@5/dist/maplibre-gl.js"></script>

<!-- ═══ Módulos de la app (el orden importa) ═══ -->
