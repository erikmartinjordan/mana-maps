rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(handle) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(handle))
        && get(/databases/$(database)/documents/users/$(handle)).data.uid == request.auth.uid;
    }

    function keepsUserOwner() {
      return request.resource.data.uid == request.auth.uid
        && !('email' in request.resource.data);
    }

    match /events/{doc} {
      allow read, write: if true;
    }

    match /stats/{doc} {
      allow read, write: if false;
    }

    // User profiles are keyed by handle: /users/{handle}.
    // Signed-in users may get a handle doc so the app can check availability.
    match /users/{handle} {
      allow get: if signedIn();
      // Needed for the uid lookup used after sign-in; individual writes still require ownership.
      allow list: if signedIn();
      allow create: if signedIn() && keepsUserOwner();
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && keepsUserOwner();
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;

      match /maps/{mapId} {
        allow read, write: if ownsUserDoc(handle);

        match /geoChunks/{chunkId} {
          allow read, write: if ownsUserDoc(handle);
        }
      }
    }

    match /maps/{mapId} {
      // Public links can read map payloads and public gallery entries.
      allow read: if true;

      // Map creation supports both editor payloads (createdBy) and public index docs (authorHandle).
      allow create: if signedIn()
        && (
          request.resource.data.createdBy == request.auth.uid
          || (request.resource.data.authorHandle is string && ownsUserDoc(request.resource.data.authorHandle))
        );

      // Authenticated collaborators can update/delete editor map docs.
      // Public gallery index docs remain restricted to their author when authorHandle is present.
      allow update, delete: if signedIn()
        && (
          !('authorHandle' in resource.data)
          || ownsUserDoc(resource.data.authorHandle)
        );

      match /presence/{userId} {
        allow read: if true;
        allow create, update, delete: if signedIn()
          && request.auth.uid == userId
          && request.resource.data.uid == request.auth.uid;
      }

      match /geoChunks/{chunkId} {
        allow read: if true;
        allow create, update, delete: if signedIn();
      }
    }
  }
}
