rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(handle) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(handle))
        && get(/databases/$(database)/documents/users/$(handle)).data.uid == request.auth.uid;
    }

    function keepsUserOwner() {
      return request.resource.data.uid == request.auth.uid
        && !('email' in request.resource.data);
    }

    function publicMapExists(mapId) {
      return exists(/databases/$(database)/documents/maps/$(mapId));
    }

    function publicMapData(mapId) {
      return get(/databases/$(database)/documents/maps/$(mapId)).data;
    }

    function canWritePublicMap(mapId) {
      return signedIn()
        && publicMapExists(mapId)
        && (
          publicMapData(mapId).ownerUid == request.auth.uid
          || (publicMapData(mapId).authorHandle is string && ownsUserDoc(publicMapData(mapId).authorHandle))
          || (publicMapData(mapId).shareMode == 'edit' && publicMapData(mapId).allowPublicEdit == true)
          || (!('authorHandle' in publicMapData(mapId)) && !('ownerUid' in publicMapData(mapId)))
        );
    }

    function publicMapViewsIncrement() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])
        && (
          ('views' in resource.data && request.resource.data.views == resource.data.views + 1)
          || (!('views' in resource.data) && request.resource.data.views == 1)
        );
    }

    function publicMapLikesIncrement() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
        && (
          ('likes' in resource.data && request.resource.data.likes == resource.data.likes + 1)
          || (!('likes' in resource.data) && request.resource.data.likes == 1)
        );
    }

    function canIncrementPublicMapEngagement() {
      return resource.data.isPublished == true
        && (
          publicMapViewsIncrement()
          || (signedIn() && publicMapLikesIncrement())
        );
    }


    function isGuestPresenceId(userId) {
      return userId is string
        && userId.matches('guest-[A-Za-z0-9]{8}');
    }

    function validPresenceCursor() {
      return !('cursor' in request.resource.data)
        || request.resource.data.cursor == null
        || (
          request.resource.data.cursor.keys().hasOnly(['lat', 'lng', 'updatedAtMs'])
          && request.resource.data.cursor.lat is number
          && request.resource.data.cursor.lng is number
          && request.resource.data.cursor.updatedAtMs is number
        );
    }

    function validPresencePayload(userId) {
      return request.resource.data.keys().hasOnly([
          'uid', 'displayName', 'color', 'name', 'activity', 'clientId',
          'guestPresence', 'cursor', 'lastSeen', 'updatedAt', 'updatedAtMs', 'lastSeenMs'
        ])
        && request.resource.data.uid == userId
        && request.resource.data.displayName is string
        && request.resource.data.name is string
        && request.resource.data.color is string
        && request.resource.data.activity is string
        && request.resource.data.clientId is string
        && request.resource.data.guestPresence is bool
        && request.resource.data.updatedAtMs is number
        && request.resource.data.lastSeenMs is number
        && validPresenceCursor();
    }

    function canWriteOwnPresence(mapId, userId) {
      return validPresencePayload(userId)
        && (
          (signedIn() && request.auth.uid == userId)
          || (!signedIn()
            && isGuestPresenceId(userId)
            && request.resource.data.guestPresence == true
            && request.resource.data.clientId == userId
            && publicMapExists(mapId)
            && publicMapData(mapId).shareMode == 'edit'
            && publicMapData(mapId).allowPublicEdit == true)
        );
    }

    function canDeleteOwnPresence(mapId, userId) {
      return (signedIn() && request.auth.uid == userId && resource.data.uid == request.auth.uid)
        || (!signedIn()
          && isGuestPresenceId(userId)
          && resource.data.guestPresence == true
          && resource.data.clientId == userId
          && publicMapExists(mapId)
          && publicMapData(mapId).shareMode == 'edit'
          && publicMapData(mapId).allowPublicEdit == true);
    }

    match /events/{doc} {
      allow read, write: if true;
    }

    match /stats/{doc} {
      allow read, write: if false;
    }

    // User profiles are keyed by handle: /users/{handle}.
    // Handle docs are public profiles; public get lets the app check handle availability
    // before Firestore has refreshed signed-in credentials after a popup redirect.
    match /users/{handle} {
      allow get: if true;
      // Needed for the uid lookup used after sign-in; individual writes still require ownership.
      allow list: if signedIn();
      allow create: if signedIn() && keepsUserOwner();
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && keepsUserOwner();
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;

      match /maps/{mapId} {
        allow read, write: if ownsUserDoc(handle);

        match /geoChunks/{chunkId} {
          allow read, write: if ownsUserDoc(handle);
        }
      }
    }

    match /collabRooms/{roomId} {
      allow read: if true;
      allow create, update: if signedIn()
        && (
          !exists(/databases/$(database)/documents/maps/$(roomId))
          || get(/databases/$(database)/documents/maps/$(roomId)).data.shareMode == 'edit'
          || get(/databases/$(database)/documents/maps/$(roomId)).data.ownerUid == request.auth.uid
        );
      allow delete: if signedIn()
        && exists(/databases/$(database)/documents/maps/$(roomId))
        && get(/databases/$(database)/documents/maps/$(roomId)).data.ownerUid == request.auth.uid;
    }

    match /maps/{mapId} {
      // Public links can read map payloads and public gallery entries.
      allow read: if true;

      // Map creation supports both editor payloads (createdBy) and public index docs (authorHandle).
      allow create: if signedIn()
        && (
          request.resource.data.createdBy == request.auth.uid
          || (request.resource.data.authorHandle is string && ownsUserDoc(request.resource.data.authorHandle))
        );

      // Owners can always update/delete their shared maps. Non-owners may only
      // collaborate when the owner explicitly shared the map in edit mode.
      allow update: if canIncrementPublicMapEngagement()
        || (signedIn()
          && (
            resource.data.ownerUid == request.auth.uid
            || (resource.data.authorHandle is string && ownsUserDoc(resource.data.authorHandle))
            || (resource.data.shareMode == 'edit' && resource.data.allowPublicEdit == true)
            || (!('authorHandle' in resource.data) && !('ownerUid' in resource.data))
          ));
      allow delete: if signedIn()
        && (
          resource.data.ownerUid == request.auth.uid
          || (resource.data.authorHandle is string && ownsUserDoc(resource.data.authorHandle))
          || (resource.data.shareMode == 'edit' && resource.data.allowPublicEdit == true)
          || (!('authorHandle' in resource.data) && !('ownerUid' in resource.data))
        );

      match /presence/{userId} {
        allow read: if true;
        allow create, update: if canWriteOwnPresence(mapId, userId);
        allow delete: if canDeleteOwnPresence(mapId, userId);
      }

      match /geoChunks/{chunkId} {
        allow read: if true;
        allow create, update, delete: if canWritePublicMap(mapId);
      }
    }
  }
}
